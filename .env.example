# IoT Gateway Security Lab - Environment Configuration
# Copy this file to .env and adjust values as needed

# Authentication token for devices
GATEWAY_AUTH_TOKEN=demo-secure-token-2024

# Comma-separated list of allowed device IDs
GATEWAY_ALLOWED_DEVICES=sensor-001,sensor-002

# Sensor range thresholds
GATEWAY_MAX_TEMP=60
GATEWAY_MIN_TEMP=-20
GATEWAY_MAX_HUMIDITY=100
GATEWAY_MIN_HUMIDITY=0

# Maximum age of data in milliseconds (5 minutes = 300000)
GATEWAY_MAX_AGE_MS=300000
